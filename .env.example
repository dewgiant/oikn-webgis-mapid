# ============================================================
# Environment Variables — OIKN WebGIS Training
# Salin file ini menjadi .env dan sesuaikan nilainya
# ============================================================

# PostgreSQL / PostGIS
POSTGRES_USER=gisuser
POSTGRES_PASSWORD=gispassword
POSTGRES_DB=gisdb

# GeoServer
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=geoserver

# App
APP_ENV=development
