let currentBasemap = 'osm';

function setBasemap(type) {
  if (currentBasemap === type) return;
  currentBasemap = type;
  map.setStyle(BASEMAPS[type]);
  map.once('styledata', reloadAllLayers);
  document.querySelectorAll('.tab-btn').forEach((b,i) =>
    b.classList.toggle('active', ['osm','satellite','dark','topo'][i] === type));
}

function reloadAllLayers() {
  // Re-add semua source & layer
  const sources = ['kawasan','jalan','infrastruktur','lingkungan'];
  sources.forEach(s => { if (!map.getSource(s)) {
    if (s === 'kawasan') {
      map.addSource('kawasan',{type:'geojson',data:DATA.kawasan});
      map.addLayer({id:'kawasan-fill',type:'fill',source:'kawasan',paint:{'fill-color':['match',['get','jenis'],'IKN','#f97316','Hutan Lindung','#15803d','Industri','#64748b','Permukiman','#3b82f6','Hutan Mangrove','#059669','Pertambangan','#92400e','#94a3b8'],'fill-opacity':0.25}});
      map.addLayer({id:'kawasan-stroke',type:'line',source:'kawasan',paint:{'line-color':['match',['get','jenis'],'IKN','#f97316','Hutan Lindung','#15803d','Industri','#64748b','Permukiman','#3b82f6','Hutan Mangrove','#059669','Pertambangan','#92400e','#94a3b8'],'line-width':1.5}});
    }
    if (s === 'jalan') {
      map.addSource('jalan',{type:'geojson',data:DATA.jalan});
      map.addLayer({id:'jalan-bg',type:'line',source:'jalan',paint:{'line-color':'#0b1120','line-width':4,'line-opacity':0.5}});
      map.addLayer({id:'jalan-line',type:'line',source:'jalan',paint:{'line-color':['match',['get','kelas'],'Tol','#f59e0b','Nasional','#ef4444','Provinsi','#94a3b8','#64748b'],'line-width':['match',['get','kelas'],'Tol',3,'Nasional',2.5,'Provinsi',1.5,1.5]}});
    }
    if (s === 'infrastruktur') {
      map.addSource('infrastruktur',{type:'geojson',data:DATA.infrastruktur});
      map.addLayer({id:'infrastruktur',type:'circle',source:'infrastruktur',paint:{'circle-radius':8,'circle-color':['match',['get','kategori'],'Transportasi','#3b82f6','Energi','#f59e0b','Air','#06b6d4','Telekomunikasi','#8b5cf6','Kesehatan','#ef4444','Pendidikan','#10b981','Pemerintahan','#f97316','#94a3b8'],'circle-stroke-width':2,'circle-stroke-color':'#fff'}});
    }
    if (s === 'lingkungan') {
      map.addSource('lingkungan',{type:'geojson',data:DATA.lingkungan});
      map.addLayer({id:'lingkungan',type:'circle',source:'lingkungan',paint:{'circle-radius':7,'circle-color':['match',['get','status_baku'],'Normal','#10b981','Waspada','#f59e0b','Kritis','#ef4444','#94a3b8'],'circle-stroke-width':2,'circle-stroke-color':'#fff'}});
    }
  }});
  setupClickHandlers();
  setupHoverEffects();
}

function toggleLayer(layerId, layerId2, visible) {
  const v = visible ? 'visible' : 'none';
  if (map.getLayer(layerId)) map.setLayoutProperty(layerId, 'visibility', v);
  if (layerId2 && map.getLayer(layerId2)) map.setLayoutProperty(layerId2, 'visibility', v);
}

let hiddenKategori = new Set();
function filterInfra(kategori, visible) {
  if (!visible) hiddenKategori.add(kategori); else hiddenKategori.delete(kategori);
  const filter = hiddenKategori.size === 0 ? null :
    ['!', ['in', ['get','kategori'], ['literal', [...hiddenKategori]]]];
  if (map.getLayer('infrastruktur')) map.setFilter('infrastruktur', filter);
  if (map.getLayer('infra-label')) map.setFilter('infra-label', filter);
}

let hiddenJalan = new Set();
function filterJalan(kelas, visible) {
  if (!visible) hiddenJalan.add(kelas.charAt(0).toUpperCase()+kelas.slice(1));
  else hiddenJalan.delete(kelas.charAt(0).toUpperCase()+kelas.slice(1));
  const filter = hiddenJalan.size === 0 ? null :
    ['!', ['in', ['get','kelas'], ['literal', [...hiddenJalan]]]];
  if (map.getLayer('jalan-line')) map.setFilter('jalan-line', filter);
  if (map.getLayer('jalan-bg'))   map.setFilter('jalan-bg', filter);
}

function toggleWMS(enabled) {
  const WMS = 'http://localhost:8080/geoserver/oikn/wms';
  const LAYER = 'oikn:kawasan';
  if (enabled) {
    if (!map.getSource('wms')) {
      map.addSource('wms', {type:'raster',tiles:[`${WMS}?service=WMS&version=1.1.1&request=GetMap&layers=${LAYER}&bbox={bbox-epsg-3857}&width=256&height=256&srs=EPSG:3857&format=image/png&transparent=true`],tileSize:256});
      map.addLayer({id:'wms-layer',type:'raster',source:'wms',paint:{'raster-opacity':0.7}});
    } else { map.setLayoutProperty('wms-layer','visibility','visible'); }
  } else {
    if (map.getLayer('wms-layer')) map.setLayoutProperty('wms-layer','visibility','none');
  }
}
</script>
</body>
